/*
 * Left half (central) — split input proxy + listener for TPS43 touchpad.
 *
 * No touchpad hardware lives on this side. The `tps43_split` node here is a
 * virtual proxy (matching `reg = <0>` on the right half's forwarder); when
 * the peripheral sends an input event over BLE, the central routes it to
 * this proxy, and the listener below converts it to HID mouse reports over
 * USB / BLE.
 *
 * Axis correction + sensitivity + layer-scoped transforms all live here on
 * the central (post-driver) via zmk,input-processor-transform /
 * zmk,input-processor-scaler / zmk,input-processor-code-mapper. This is
 * the layer-aware path: layer state is authoritative on the central, so
 * layer-conditional processors like scroll-mode and precision-mode must
 * be attached here (not on the peripheral's forwarder).
 */

#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>

/ {
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        tps43_split: tps43_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };
    };

    tps43_listener: tps43_listener {
        compatible = "zmk,input-listener";
        device = <&tps43_split>;

        /* Base: invert X (physical pad mirrored vs chip default) + scale
         * movement to 1/2 of raw (TPS43 is otherwise very fast). */
        input-processors =
            <&zip_xy_transform INPUT_TRANSFORM_X_INVERT>,
            <&zip_xy_scaler 1 2>;

        /* Precision mode (layer 6, momentary): stack an additional 1/2 scaler
         * on top of the base 1/2 via process-next. Net: 1/4 of raw movement.
         * Good for small-target clicks. Layer indices MUST match corne.keymap. */
        precision {
            layers = <6>;
            input-processors = <&zip_xy_scaler 1 2>;
            process-next;
        };

        /* Scroll mode (layer 5, momentary): re-map touchpad X/Y cursor
         * movement to scroll wheel events. Does NOT stack with base —
         * process-next intentionally omitted so only this runs. */
        scroller {
            layers = <5>;
            input-processors = <&zip_xy_to_scroll_mapper>;
        };
    };
};
