/*
 * Right half (peripheral) — touchpad hardware + split input forwarder.
 *
 * Driver: stelmakhdigital/zmk_driver_azoteq (compatible = "azoteq,tps43").
 * Per-property semantics differ from AYM1607's generic iqs5xx driver:
 *   one-finger-tap   -> single-tap
 *   natural-scroll-y -> invert-scroll-y
 *   flip-x           -> invert-x
 *   reset-gpios polarity is GPIO_ACTIVE_HIGH (not LOW) — driver code drives
 *     the pin low with set_dt(0), so logical-0 must map to physical-low.
 *
 * NRST is wired back: stelmakhdigital handles the chip's 150ms ATI requirement
 * (610ms blind sleep after release), so the AYM1607-era reset race doesn't apply.
 *
 * `enable-power-management` intentionally omitted: gates the chip's idle
 * suspend (<1uA), but stelmakhdigital disables the RDY interrupt during
 * suspend so first-touch-after-idle is swallowed. Acceptable on battery
 * where power matters; annoying on USB. Uncomment when a battery's wired.
 */

#include <zephyr/dt-bindings/i2c/i2c.h>

&pro_micro_i2c {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;   /* 100kHz, matches factory */

    tps43: trackpad@74 {
        compatible = "azoteq,tps43";
        reg = <0x74>;
        status = "okay";

        /* Pins from factory RIGHT.UF2 extraction (flash offset 0x60ae8). */
        rdy-gpios = <&gpio1 2 GPIO_ACTIVE_HIGH>;
        rst-gpios = <&gpio1 1 GPIO_ACTIVE_HIGH>;

        single-tap;
        two-finger-tap;
        press-and-hold;
        scroll;
        invert-scroll-y;
        invert-x;

        /* Filter tuning: default 0x0F = IIR + MAV + ALP + FIXED IIR coefficient,
         * which over-smooths small slow movements ("blocky" feel — small
         * deltas snap to filter-quantized increments). 0x0B drops the
         * FIXED IIR bit, switching to dynamic IIR that adapts to movement
         * speed. Heavy smoothing only at high speed; light at low. Per
         * binding docs: "good balance of stability and responsiveness." */
        filter-settings = <0x0B>;
    };
};

/ {
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        tps43_split: tps43_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
            device = <&tps43>;
        };
    };
};
